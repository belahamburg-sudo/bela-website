# Post-purchase 1-Click OTO (real off-session charges!). OFF until you set
# OTO_ENABLED=1. Test in Stripe test mode first. When on, the checkout saves the
# card and the success page offers the course below at the discount.
OTO_ENABLED=
OTO_COURSE_SLUG=ai-goldmining-method
OTO_DISCOUNT_PERCENT=50

# Trustpilot TrustBox (free) — optional override; default is the aigoldmining.com profile id
NEXT_PUBLIC_TRUSTPILOT_BUSINESS_UNIT_ID=69fdcf8486c7ed6ca15dc5a6

# Stripe checkout extras
# Fallback promo codes if Stripe Promotion Codes are not set up yet (CODE:PERCENT)
CHECKOUT_PROMO_CODES=GOLDMININGX10:10
# Set to 1 to enable Stripe Tax (account must have Stripe Tax + origin address configured)
STRIPE_AUTOMATIC_TAX=
# Set to 1 to collect Terms-of-Service consent on the Stripe page (needs a TOS URL in Stripe branding)
STRIPE_TOS_CONSENT=
